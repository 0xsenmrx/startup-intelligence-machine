# Startup Intelligence Machine Configuration
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: Tier detection (pro/free) - usually auto-detected from key
# GEMINI_TIER=free

# Optional: Debug mode for verbose logging
# DEBUG=false
